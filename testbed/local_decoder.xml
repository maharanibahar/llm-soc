<decoder name="modsecurity-json">
  <prematch type="pcre2">^\{</prematch>
  <plugin_decoder>JSONDecoder</plugin_decoder>
</decoder>

<decoder name="modsecurity-json">
  <parent>modsecurity-json</parent>
  <regex type="pcre2">"client_ip":"(\S+)"</regex>
  <order>srcip</order>
</decoder>

<decoder name="modsecurity-json">
  <parent>modsecurity-json</parent>
  <regex type="pcre2">"uri":"(\S+)"</regex>
  <order>url</order>
</decoder>

<decoder name="modsecurity-json">
  <parent>modsecurity-json</parent>
  <regex type="pcre2">"id":"(\d+)"</regex>
  <order>rule_id</order>
</decoder>

<decoder name="modsecurity-json">
  <parent>modsecurity-json</parent>
  <regex type="pcre2">"msg":"([^"]+)"</regex>
  <order>extra_data</order>
</decoder>
