<!--
  Custom Decoders for LLM-SOC Pipeline
  Handles: ModSecurity inline alerts in nginx error logs
  Note: Nginx access logs use Wazuh's built-in decoder
-->

<!-- ModSecurity inline alerts in nginx error.log -->
<decoder name="modsec-inline">
  <prematch>ModSecurity: </prematch>
</decoder>

<decoder name="modsec-inline-fields">
  <parent>modsec-inline</parent>
  <regex>\[client (\S+)\]</regex>
  <order>srcip</order>
</decoder>

<decoder name="modsec-inline-fields">
  <parent>modsec-inline</parent>
  <regex>\[id "(\d+)"\]</regex>
  <order>modsec_rule_id</order>
</decoder>

<decoder name="modsec-inline-fields">
  <parent>modsec-inline</parent>
  <regex>\[msg "([^"]+)"\]</regex>
  <order>modsec_msg</order>
</decoder>

<decoder name="modsec-inline-fields">
  <parent>modsec-inline</parent>
  <regex>\[severity "(\d+)"\]</regex>
  <order>modsec_severity</order>
</decoder>

<decoder name="modsec-inline-fields">
  <parent>modsec-inline</parent>
  <regex>\[uri "([^"]+)"\]</regex>
  <order>url</order>
</decoder>

<decoder name="modsec-inline-fields">
  <parent>modsec-inline</parent>
  <regex>Total Score: (\d+)</regex>
  <order>modsec_score</order>
</decoder>

<decoder name="modsec-inline-fields">
  <parent>modsec-inline</parent>
  <regex>Access denied \(code (\d+)\)</regex>
  <order>status</order>
</decoder>
