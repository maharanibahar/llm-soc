<!--
  Custom Rules for LLM-SOC Pipeline
  Purpose: Tag events with attack classification for the LLM pipeline
  Key: Low rule levels (1-3) so ALL events are captured in archives.json
-->
<group name="llm-soc,web-attacks,">

  <!-- ============================================================ -->
  <!-- CATCH-ALL: Log every nginx/modsec event at low level         -->
  <!-- ============================================================ -->

  <rule id="100001" level="1">
    <decoded_as>modsec-inline</decoded_as>
    <description>ModSecurity event detected</description>
    <group>modsecurity</group>
  </rule>

  <rule id="100002" level="1">
    <decoded_as>nginx-access</decoded_as>
    <description>Nginx access log entry</description>
    <group>nginx</group>
  </rule>

  <!-- ============================================================ -->
  <!-- SQL INJECTION DETECTION (OWASP CRS 942xxx)                   -->
  <!-- ============================================================ -->

  <rule id="100010" level="5">
    <if_sid>100001</if_sid>
    <match>SQL Injection</match>
    <description>SQL Injection attempt detected</description>
    <mitre>
      <id>T1190</id>
    </mitre>
    <group>sqli,attack</group>
  </rule>

  <rule id="100011" level="5">
    <if_sid>100001</if_sid>
    <regex>id "942\d\d\d"</regex>
    <description>SQL Injection (CRS rule 942xxx)</description>
    <mitre>
      <id>T1190</id>
    </mitre>
    <group>sqli,attack</group>
  </rule>

  <!-- ============================================================ -->
  <!-- XSS DETECTION (OWASP CRS 941xxx)                             -->
  <!-- ============================================================ -->

  <rule id="100020" level="5">
    <if_sid>100001</if_sid>
    <match>XSS|Cross-Site Scripting</match>
    <description>XSS attempt detected</description>
    <mitre>
      <id>T1059.007</id>
    </mitre>
    <group>xss,attack</group>
  </rule>

  <rule id="100021" level="5">
    <if_sid>100001</if_sid>
    <regex>id "941\d\d\d"</regex>
    <description>XSS attack (CRS rule 941xxx)</description>
    <mitre>
      <id>T1059.007</id>
    </mitre>
    <group>xss,attack</group>
  </rule>

  <!-- ============================================================ -->
  <!-- SCANNER DETECTION (OWASP CRS 913xxx)                         -->
  <!-- ============================================================ -->

  <rule id="100030" level="3">
    <if_sid>100001</if_sid>
    <match>Scanner|scanning</match>
    <description>Vulnerability scanner detected</description>
    <mitre>
      <id>T1595.001</id>
    </mitre>
    <group>webscan,recon</group>
  </rule>

  <rule id="100031" level="3">
    <if_sid>100001</if_sid>
    <regex>id "913\d\d\d"</regex>
    <description>Scanner detection (CRS rule 913xxx)</description>
    <mitre>
      <id>T1595.001</id>
    </mitre>
    <group>webscan,recon</group>
  </rule>

  <!-- ============================================================ -->
  <!-- PATH TRAVERSAL / LFI (OWASP CRS 930xxx)                      -->
  <!-- ============================================================ -->

  <rule id="100040" level="5">
    <if_sid>100001</if_sid>
    <match>Path Traversal|Directory traversal|LFI</match>
    <description>Path traversal attempt detected</description>
    <mitre>
      <id>T1083</id>
    </mitre>
    <group>pathtraversal,attack</group>
  </rule>

  <rule id="100041" level="5">
    <if_sid>100001</if_sid>
    <regex>id "930\d\d\d"</regex>
    <description>Path traversal (CRS rule 930xxx)</description>
    <mitre>
      <id>T1083</id>
    </mitre>
    <group>pathtraversal,attack</group>
  </rule>

  <!-- ============================================================ -->
  <!-- BRUTE FORCE / AUTHENTICATION                                 -->
  <!-- ============================================================ -->

  <rule id="100050" level="5">
    <if_sid>100002</if_sid>
    <match>POST /rest/user/login</match>
    <status>401</status>
    <description>Failed login attempt</description>
    <mitre>
      <id>T1110.001</id>
    </mitre>
    <group>bruteforce,authentication</group>
  </rule>

  <!-- ============================================================ -->
  <!-- ANOMALY SCORE EXCEEDED (catches anything CRS flags)          -->
  <!-- ============================================================ -->

  <rule id="100060" level="5">
    <if_sid>100001</if_sid>
    <match>Anomaly Score Exceeded</match>
    <description>ModSecurity anomaly score threshold exceeded</description>
    <group>anomaly,waf-block</group>
  </rule>

  <!-- ============================================================ -->
  <!-- ACCESS DENIED (WAF blocked the request)                      -->
  <!-- ============================================================ -->

  <rule id="100070" level="4">
    <if_sid>100001</if_sid>
    <match>Access denied</match>
    <description>ModSecurity blocked request (403)</description>
    <group>waf-block</group>
  </rule>

</group>
